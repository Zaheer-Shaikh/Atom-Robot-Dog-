void runTrotCycle() {
  float FrontX = 0.5, BackX = -0.3, FloorY = -12.0, MidX = 0.1, AirY = -10.5;    
  
  interpolation(BackX, FloorY, MidX, AirY, FrontX, FloorY, MidX, FloorY, 12); 
  if (currentState != STATE_WALK) return;
  interpolation(MidX, AirY, FrontX, FloorY, MidX, FloorY, BackX, FloorY, 12); 
  if (currentState != STATE_WALK) return;
  interpolation(FrontX, FloorY, MidX, FloorY, BackX, FloorY, MidX, AirY, 12); 
  if (currentState != STATE_WALK) return;
  interpolation(MidX, FloorY, BackX, FloorY, MidX, AirY, FrontX, FloorY, 12); 
}

void runSayHiiCycle() {
  moveLeg(1, 42, 60, 100);
  moveLeg(3, 31, 170, 70);
  moveLeg(4, 47, 170, 70);

  for (int targetFemur = 130; targetFemur <= 160; targetFemur++) {
    if (currentState != STATE_SAY_HII) return; 
    l2Angles[1] = targetFemur; 
    moveLeg(2, 43, l2Angles[1], 130);
    delay(7); 
  }
  
  for(int i=0; i<20; i++) { Blynk.run(); delay(10); if (currentState != STATE_SAY_HII) return; }

  for (int targetFemur = 160; targetFemur >= 130; targetFemur--) {
    if (currentState != STATE_SAY_HII) return;
    l2Angles[1] = targetFemur; 
    moveLeg(2, 43, l2Angles[1], 130);
    delay(7); 
  }
  
  for(int i=0; i<20; i++) { Blynk.run(); delay(10); if (currentState != STATE_SAY_HII) return; }
}

// --- LOWER LEVEL UTILITIES ---

int IK(float x, float y, int legChosed, bool first) {
  y = -y;
  float c2 = (x * x + y * y - L1 * L1 - L2 * L2) / (2 * L1 * L2);
  c2 = constrain(c2, -1.0, 1.0);
  float theta2 = atan2(-sqrt(1 - c2 * c2), c2);  
  float k1 = L1 + L2 * cos(theta2);
  float k2 = L2 * sin(theta2);
  float theta1 = atan2(y, x) - atan2(k2, k1);
  int angle1 = theta1 * 180.0 / PI;
  int angle2 = abs(theta2 * 180.0 / PI); 

  angle1 = constrain(angle1, 10, 170); 
  angle2 = constrain(angle2, 10, 90);  

  if (legChosed == 1) {
    Servo1 = 0; Servo2 = 1;
    return first ? map(angle1, 180, 0, SERVOMIN0, SERVOMAX0) : map(angle2, 90, 0, SERVOMIN1, SERVOMAX1);
  } else if (legChosed == 2) {
    Servo1 = 3; Servo2 = 4;
    return first ? map(angle1, 0, 180, SERVOMIN3, SERVOMAX3) : map(angle2, 0, 90, SERVOMIN4, SERVOMAX4);       
  } else if (legChosed == 3) {
    Servo1 = 6; Servo2 = 7;
    return first ? map(angle1, 180, 0, SERVOMIN6, SERVOMAX6) : map(angle2, 90, 0, SERVOMIN7, SERVOMAX7);  
  } else if (legChosed == 4) {
    Servo1 = 9; Servo2 = 10;
    return first ? map(angle1, 0, 180, SERVOMIN9, SERVOMAX9) : map(angle2, 0, 90, SERVOMIN10, SERVOMAX10);
  }
  return 0;
}

int shoulderMap(int servoChosed, int angle) {
  if (servoChosed == 1) return map(angle, 0, 90, SERVOMIN2, SERVOMAX2);
  if (servoChosed == 2) return map(angle, 90, 0, SERVOMIN5, SERVOMAX5);
  if (servoChosed == 3) return map(angle, 90, 0, SERVOMIN8, SERVOMAX8);
  if (servoChosed == 4) return map(angle, 0, 90, SERVOMIN11, SERVOMAX11);
  return 0;
}

void interpolation(float startX1, float startY1, float endX1, float endY1, float startX2, float startY2, float endX2, float endY2, float steps) {
  for (float i = 1; i <= steps; i++) {
    Blynk.run(); 
    if (currentState != STATE_WALK) return;

    float currX1 = startX1 + ((endX1 - startX1) * (i / steps));
    float currY1 = startY1 + ((endY1 - startY1) * (i / steps));
    float currX2 = startX2 + ((endX2 - startX2) * (i / steps));
    float currY2 = startY2 + ((endY2 - startY2) * (i / steps));

    pwm.setPWM(2, 0, shoulderMap(1, bas1));  
    pwm.setPWM(5, 0, shoulderMap(2, bas2)); 
    pwm.setPWM(8, 0, shoulderMap(3, bas3));  
    pwm.setPWM(11, 0, shoulderMap(4, bas4)); 

    pwm.setPWM(0, 0, IK(currX1, currY1, 1, true));  pwm.setPWM(1, 0, IK(currX1, currY1, 1, false));
    pwm.setPWM(9, 0, IK(currX1, currY1, 4, true));  pwm.setPWM(10, 0, IK(currX1, currY1, 4, false));
    pwm.setPWM(3, 0, IK(currX2, currY2, 2, true));  pwm.setPWM(4, 0, IK(currX2, currY2, 2, false));
    pwm.setPWM(6, 0, IK(currX2, currY2, 3, true));  pwm.setPWM(7, 0, IK(currX2, currY2, 3, false));
    delay(10); 
  }
}

void moveLeg(int leg, int sh, int fem, int tib) {
  int idx = leg - 1;
  int fPulse = map(fem, (idx % 2 == 0) ? 180 : 0, (idx % 2 == 0) ? 0 : 180, limits[idx][0], limits[idx][1]);
  int tPulse = map(tib, (idx % 2 == 0) ? 90 : 0,  (idx % 2 == 0) ? 0 : 90,  limits[idx][2], limits[idx][3]);
  int sPulse = map(sh,  (idx == 0 || idx == 3) ? 0 : 90, (idx == 0 || idx == 3) ? 90 : 0, 150, 450);

  int baseChannel = idx * 3;
  pwm.setPWM(baseChannel,     0, fPulse);
  pwm.setPWM(baseChannel + 1, 0, tPulse);
  pwm.setPWM(baseChannel + 2, 0, sPulse);
}
