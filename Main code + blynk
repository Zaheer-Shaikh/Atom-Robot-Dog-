void setup() {
  Serial.begin(115200); 
  delay(10);
  
  Wire.begin(); 
  pwm.begin();        
  pwm.setPWMFreq(50); 
  
  // 1. FORCED BOOT SAFETY: Lock into standing position instantly
  executeStandPose();
  delay(1000); 

  // 2. Manual Non-Blocking Wi-Fi Initialization
  Serial.print("Connecting to WiFi...");
  WiFi.begin(ssid, pass);

  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println("\nWiFi Connected!");
  Serial.print("IP Address: ");
  Serial.println(WiFi.localIP());
  
  // 3. Mount Blynk network layout profile
  Blynk.config(BLYNK_AUTH_TOKEN);
  Serial.println("Blynk Config Loaded. Authenticating...");
  
  // 4. Verification Check: Wait up to 4 seconds to see if Blynk links up
  int timeout = 0;
  while (Blynk.connect() == false && timeout < 8) {
    delay(500);
    Serial.print("?");
    timeout++;
  }

  if (Blynk.connected()) {
    Serial.println("\n[SUCCESS] Blynk Cloud is Connected! 🚀");
  } else {
    Serial.println("\n[ERROR] WiFi is OK, but Blynk Connection Failed.");
  }
}

void loop() {
  Blynk.run(); // Keeps wireless data tracking active live
  
  // State controller loop switcher
  switch (currentState) {
    case STATE_STAND:
      executeStandPose();
      break;
    case STATE_WALK:
      runTrotCycle();
      break;
    case STATE_SIT:
      executeSitPose();
      break;
    case STATE_SAY_HII:
      runSayHiiCycle();
      break;
  }
}

